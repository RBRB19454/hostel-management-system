    "@heroicons/react": "^2.1.3",
    "axios": "^1.13.2",
    "cloudinary": "^2.8.0",
    "framer-motion": "^12.23.24",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.23.0",
    "react-router-hash-link": "^2.4.3",
    "recharts": "^2.12.6",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
